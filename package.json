{
  "name": "fdtd-2d-simulator",
  "version": "0.1.0",
  "private": true,
  "description": "Browser-based 2D FDTD teaching and research simulator.",
  "scripts": {
    "test": "node scripts/validate-static.mjs",
    "validate": "node scripts/validate-static.mjs --json",
    "test:browser": "node scripts/browser-smoke.mjs",
    "benchmark:perf": "node scripts/performance-benchmark.mjs",
    "build:wasm:wat": "powershell -ExecutionPolicy Bypass -File scripts/build-wasm.ps1",
    "build:wasm:cpp": "powershell -ExecutionPolicy Bypass -File scripts/build-wasm-cpp.ps1"
  },
  "devDependencies": {
    "playwright": "^1.55.0"
  }
}
